      //- ===== STATS =====
      section.stats
        .container
          .stats__grid
            .stat-card
              .stat-card__number(data-target="127")
                span.stat-card__count 0
              .stat-card__label アイテム
              .stat-card__desc ゲーム内全アイテムに対応
            .stat-card
              .stat-card__number(data-target="107")
