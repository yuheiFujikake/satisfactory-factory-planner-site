doctype html
html(lang="ja")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    meta(name="description" content="Satisfactory の工場生産計画を自動化する無料Webツール。生産目標を設定するだけで、必要な原材料・製造機械数・電力消費量を瞬時に計算。依存関係グラフで生産ラインを可視化します。")
    meta(name="keywords" content="Satisfactory, factory planner, 工場計画, 生産計算, サティスファクトリー, 生産ライン, 工場最適化, ゲームツール")
    meta(name="author" content="Satisfactory Factory Planner")
    meta(name="robots" content="index, follow")

    //- OGP
    meta(property="og:type" content="website")
    meta(property="og:title" content="Satisfactory Factory Planner — 工場生産計画を自動計算")
    meta(property="og:description" content="生産目標を設定するだけ。必要な原材料・製造機械数・電力消費量を瞬時に自動計算。Satisfactory プレイヤーのための無料Webツール。")
    meta(property="og:image" content="https://yuheifujikake.github.io/satisfactory-factory-planner-site/screenshots/screen-main.png")
    meta(property="og:url" content="https://yuheifujikake.github.io/satisfactory-factory-planner-site/")
    meta(property="og:site_name" content="Satisfactory Factory Planner")
    meta(property="og:locale" content="ja_JP")

    //- Twitter Card
    meta(name="twitter:card" content="summary_large_image")
    meta(name="twitter:title" content="Satisfactory Factory Planner — 工場生産計画を自動計算")
    meta(name="twitter:description" content="生産目標を設定するだけ。必要な原材料・製造機械数・電力消費量を瞬時に自動計算。")
    meta(name="twitter:image" content="https://yuheifujikake.github.io/satisfactory-factory-planner-site/screenshots/screen-main.png")

    title Satisfactory Factory Planner — 工場生産計画を自動計算

    link(rel="icon" type="image/svg+xml" href="/favicon.svg")
    link(rel="preconnect" href="https://fonts.googleapis.com")
    link(rel="preconnect" href="https://fonts.gstatic.com" crossorigin)
    link(href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet")
    link(rel="stylesheet" href="/src/scss/main.scss")

    //- JSON-LD Structured Data
    script(type="application/ld+json").
      {
        "@context": "https://schema.org",
        "@type": "WebApplication",
        "name": "Satisfactory Factory Planner",
        "description": "Satisfactoryの工場生産計画を自動化するWebツール。生産目標から必要な原材料・機械数・電力消費を自動計算。",
        "url": "https://yuheifujikake.github.io/satisfactory-factory-planner-site/",
        "applicationCategory": "GameApplication",
        "operatingSystem": "Any",
        "offers": {
          "@type": "Offer",
          "price": "0",
          "priceCurrency": "JPY"
        },
        "author": {
          "@type": "Person",
          "name": "yuheiFujikake"
        },
        "featureList": [
          "自動生産計算",
          "依存関係グラフ可視化",
          "電力消費計算",
          "代替レシピ対応",
          "マルチプラン管理",
          "日本語・英語対応"
        ]
      }

  body
    //- Scroll progress bar
    .scroll-progress
      .scroll-progress__bar

    //- Header
    header.header
      nav.nav.container
        a.nav__logo(href="#hero")
          .nav__logo-icon
            svg(width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg")
              rect(x="2" y="10" width="4" height="4" rx="0.5" fill="currentColor" opacity="0.9")
              rect(x="10" y="6" width="4" height="4" rx="0.5" fill="currentColor" opacity="0.9")
              rect(x="10" y="14" width="4" height="4" rx="0.5" fill="currentColor" opacity="0.9")
              rect(x="18" y="10" width="4" height="4" rx="0.5" fill="currentColor" opacity="0.9")
              line(x1="6" y1="12" x2="10" y2="8" stroke="currentColor" stroke-width="1.5" opacity="0.6")
              line(x1="6" y1="12" x2="10" y2="16" stroke="currentColor" stroke-width="1.5" opacity="0.6")
              line(x1="14" y1="8" x2="18" y2="12" stroke="currentColor" stroke-width="1.5" opacity="0.6")
              line(x1="14" y1="16" x2="18" y2="12" stroke="currentColor" stroke-width="1.5" opacity="0.6")
          span.nav__logo-text SFP
        ul.nav__links
          li
            a.nav__link(href="#about") ツールについて
          li
            a.nav__link(href="#features") 機能
          li
            a.nav__link(href="#howto") 使い方
          li
            a.nav__link(href="#feedback") フィードバック
        a.nav__cta.btn.btn--primary(href="https://satisfactory-factory-planner.vercel.app/" target="_blank" rel="noopener")
          span ツールを使う
          svg(width="14" height="14" viewBox="0 0 14 14" fill="none")
            path(d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round")
        button.nav__menu-btn(aria-label="メニュー" aria-expanded="false")
          span
          span
          span

    //- Mobile menu
    .nav__mobile-menu
      ul.nav__mobile-links
        li
          a(href="#about") ツールについて
        li
          a(href="#features") 機能
        li
          a(href="#howto") 使い方
        li
          a(href="#feedback") フィードバック
        li
          a.btn.btn--primary(href="https://satisfactory-factory-planner.vercel.app/" target="_blank" rel="noopener") ツールを使う

    main
      //- ===== HERO =====
      section.hero#hero
        canvas.hero__canvas
        .hero__bg-grid
        .container
          .hero__content
            .hero__badge
              span.hero__badge-dot
              span Satisfactory 工場計画ツール &nbsp;—&nbsp; 完全無料
            h1.hero__title
              span.hero__title-line 複雑な生産ラインを
              span.hero__title-line.hero__title-line--accent 自動で最適化
            p.hero__subtitle
              | 生産目標を設定するだけ。必要な原材料・製造機械数・
              | 電力消費量を瞬時に算出します。
            .hero__actions
              a.btn.btn--primary.btn--lg(href="https://satisfactory-factory-planner.vercel.app/" target="_blank" rel="noopener")
                svg(width="18" height="18" viewBox="0 0 18 18" fill="none")
                  path(d="M9 2L9 16M2 9L16 9" stroke="currentColor" stroke-width="2" stroke-linecap="round")
                span いますぐ無料で使う
              a.btn.btn--ghost.btn--lg(href="https://github.com/yuheiFujikake/satisfactory-factory-planner" target="_blank" rel="noopener")
                svg(width="18" height="18" viewBox="0 0 24 24" fill="currentColor")
                  path(d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z")
                span GitHubで見る
          .hero__visual
            .hero__screen-mock
              .hero__screen-mock-bar
                span
                span
                span
              .hero__screen-mock-body
                .hero__mock-stats
                  .hero__mock-stat
                    span.hero__mock-stat-label 総電力
                    span.hero__mock-stat-value 87.0 MW
                  .hero__mock-stat
                    span.hero__mock-stat-label アイテム種類
                    span.hero__mock-stat-value 6
                  .hero__mock-stat
                    span.hero__mock-stat-label 建物種類
                    span.hero__mock-stat-value 4
                  .hero__mock-stat
                    span.hero__mock-stat-label 総建物数
                    span.hero__mock-stat-value 6
                table.hero__mock-table
                  thead
                    tr
                      th アイテム
                      th 必要量/分
                      th 建物
                      th 必要台数
                  tbody
                    tr.hero__mock-row--target
                      td 回路基板
                      td.hero__mock-highlight 7.5
