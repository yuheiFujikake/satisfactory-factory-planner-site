                      td.hero__mock-highlight 30
                      td 製錬炉
                      td 1
                    tr.hero__mock-row--raw
                      td 原油 raw
                      td.hero__mock-highlight 45
                      td —
                      td —
                    tr.hero__mock-row--raw
                      td 銅鉱石 raw
                      td.hero__mock-highlight 30
                      td —
                      td —
        .hero__scroll-indicator
          .hero__scroll-dot
          span スクロール

      //- ===== ABOUT =====
      section.about#about
        .container
          .about__inner
            .about__text
              .section-tag ツールについて
              h2.section-title 工場計画の
                br
                span.text-accent 複雑さを解消
              p.about__lead
                | Satisfactory では、高度なアイテムを作るために
                | 膨大な数の中間素材と製造機械が必要です。
                | 手作業で計算するのは現実的ではありません。
            .about__problems
              .about__problem
                .about__problem-icon
                  svg(width="24" height="24" viewBox="0 0 24 24" fill="none")
                    path(d="M12 2L2 7l10 5 10-5-10-5z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round")
                    path(d="M2 17l10 5 10-5" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round")
                    path(d="M2 12l10 5 10-5" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round")
                .about__problem-content
                  h3 多段階レシピが複雑
                  p 回路基板ひとつ作るだけで、銅板・銅インゴット・原油・プラスチックと何十もの依存が発生します。
              .about__problem
                .about__problem-icon
                  svg(width="24" height="24" viewBox="0 0 24 24" fill="none")
                    rect(x="3" y="3" width="7" height="7" rx="1" stroke="currentColor" stroke-width="1.5")
                    rect(x="14" y="3" width="7" height="7" rx="1" stroke="currentColor" stroke-width="1.5")
                    rect(x="3" y="14" width="7" height="7" rx="1" stroke="currentColor" stroke-width="1.5")
                    rect(x="14" y="14" width="7" height="7" rx="1" stroke="currentColor" stroke-width="1.5")
                .about__problem-content
                  h3 機械数の算出が大変
                  p 生産レートと機械の出力から必要台数を計算して、さらにオーバークロックも考慮すると煩雑です。
              .about__problem
                .about__problem-icon
                  svg(width="24" height="24" viewBox="0 0 24 24" fill="none")
                    circle(cx="12" cy="12" r="3" stroke="currentColor" stroke-width="1.5")
                    path(d="M12 2v3M12 19v3M4.22 4.22l2.12 2.12M17.66 17.66l2.12 2.12M2 12h3M19 12h3M4.22 19.78l2.12-2.12M17.66 6.34l2.12-2.12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round")
                .about__problem-content
                  h3 電力消費の試算が困難
                  p 複数機械のオーバークロックを込みで電力消費を事前に把握するには専用の計算が必要です。
          .about__solution
            .about__solution-label ↓ Satisfactory Factory Planner が解決
            p.about__solution-text
              strong 目標アイテムと生産量を設定するだけ
              | で、すべてを自動計算します。

      //- ===== FEATURES =====
      section.features#features
        .container
          .section-header
            .section-tag 機能
            h2.section-title すべての計画に
              br
              span.text-accent 必要な機能を
            p.section-desc 127アイテム・107レシピ・11種類の製造機械に対応した本格的な生産計算ツールです。
          .features__grid
            .feature-card
              .feature-card__icon-wrap
                svg(width="28" height="28" viewBox="0 0 28 28" fill="none")
                  path(d="M7 14h4l3-8 4 16 3-8h4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round")
              h3.feature-card__title 自動生産計算
              p.feature-card__desc 生産目標を設定するだけで、すべての中間素材・原材料の必要量を再帰的に自動算出します。
              .feature-card__tag 計算エンジン
            .feature-card
              .feature-card__icon-wrap
                svg(width="28" height="28" viewBox="0 0 28 28" fill="none")
                  circle(cx="7" cy="14" r="2.5" stroke="currentColor" stroke-width="1.8")
                  circle(cx="21" cy="8" r="2.5" stroke="currentColor" stroke-width="1.8")
                  circle(cx="21" cy="20" r="2.5" stroke="currentColor" stroke-width="1.8")
                  line(x1="9.5" y1="13" x2="18.5" y2="9.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round")
                  line(x1="9.5" y1="15" x2="18.5" y2="18.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round")
              h3.feature-card__title 依存関係グラフ
              p.feature-card__desc 生産チェーン全体をインタラクティブなグラフで可視化。ノードの位置は自由に移動・保存できます。
              .feature-card__tag ビジュアライズ
            .feature-card
              .feature-card__icon-wrap
                svg(width="28" height="28" viewBox="0 0 28 28" fill="none")
                  path(d="M14 4v4M14 20v4M4 14h4M20 14h4" stroke="currentColor" stroke-width="2" stroke-linecap="round")
                  circle(cx="14" cy="14" r="5" stroke="currentColor" stroke-width="1.8")
                  path(d="M10 10l8 8M18 10l-8 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" opacity="0.5")
              h3.feature-card__title 電力消費計算
              p.feature-card__desc オーバークロック率（1〜250%）を設定すると、全機械の消費電力を P = 基本電力 × 比率^1.6 で正確に試算します。
              .feature-card__tag オーバークロック対応
            .feature-card
              .feature-card__icon-wrap
                svg(width="28" height="28" viewBox="0 0 28 28" fill="none")
                  path(d="M14 4C8.477 4 4 8.477 4 14s4.477 10 10 10 10-4.477 10-10S19.523 4 14 4z" stroke="currentColor" stroke-width="1.8")
                  path(d="M9 14h10M14 9v10" stroke="currentColor" stroke-width="1.8" stroke-linecap="round")
              h3.feature-card__title 代替レシピ対応
              p.feature-card__desc 複数の製造ルートを比較・切り替え。アイテムごとに最適なレシピを選択して生産効率を最大化します。
              .feature-card__tag レシピ最適化
            .feature-card
              .feature-card__icon-wrap
                svg(width="28" height="28" viewBox="0 0 28 28" fill="none")
                  rect(x="4" y="6" width="20" height="4" rx="1" stroke="currentColor" stroke-width="1.8")
                  rect(x="4" y="13" width="20" height="4" rx="1" stroke="currentColor" stroke-width="1.8")
                  rect(x="4" y="20" width="12" height="4" rx="1" stroke="currentColor" stroke-width="1.8")
              h3.feature-card__title マルチプラン管理
              p.feature-card__desc 複数の生産計画を同時に管理。JSON形式でエクスポート・インポートでき、他プレイヤーとの共有も可能です。
              .feature-card__tag プラン管理
            .feature-card
              .feature-card__icon-wrap
                svg(width="28" height="28" viewBox="0 0 28 28" fill="none")
                  circle(cx="14" cy="14" r="10" stroke="currentColor" stroke-width="1.8")
                  path(d="M14 4c0 0-4 4-4 10s4 10 4 10" stroke="currentColor" stroke-width="1.5")
                  path(d="M14 4c0 0 4 4 4 10s-4 10-4 10" stroke="currentColor" stroke-width="1.5")
                  path(d="M4 14h20" stroke="currentColor" stroke-width="1.5" stroke-linecap="round")
              h3.feature-card__title 多言語対応
              p.feature-card__desc 日本語・英語を切り替え可能。全127アイテム・全レシピが両言語に対応しています。
              .feature-card__tag 日本語 / English

